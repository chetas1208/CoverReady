# =========================
# CoverReady backend config
# =========================

# Environment label
COVERREADY_ENV=development

# Data/time anchor used by scoring and demo behavior
COVERREADY_AS_OF_DATE=2026-04-22

# Database
# Local SQLite fallback (works without Postgres):
COVERREADY_DATABASE_URL=sqlite:////home/923873155/CoverReady/apps/api/data/runtime/coverready.db
# Postgres example:
# COVERREADY_DATABASE_URL=postgresql+psycopg://coverready:coverready@localhost:5432/coverready

# Redis (used by worker/jobs)
COVERREADY_REDIS_URL=redis://localhost:6379/0

# Extraction mode: auto | fixture | nim
# - fixture: deterministic local fixtures (best quick start)
# - nim: NVIDIA NIM Parse/OCR
# - auto: choose based on NIM config presence
COVERREADY_EXTRACTOR_MODE=fixture

# Run jobs inline inside API for local/dev simplicity
COVERREADY_JOBS_EAGER=true

# Extraction quality thresholds
COVERREADY_EXTRACTION_MIN_CONFIDENCE=0.55
COVERREADY_EXTRACTION_MIN_TEXT_LENGTH=40
COVERREADY_EXTRACTION_PROMPT_VERSION=extract-v1

# Optional LLM explanation settings
# COVERREADY_OLLAMA_URL=http://localhost:11434
COVERREADY_EXPLANATION_MODEL=gemma3

# NVIDIA NIM settings (required only when COVERREADY_EXTRACTOR_MODE=nim)
# COVERREADY_NIM_BASE_URL=https://integrate.api.nvidia.com
# COVERREADY_NIM_API_KEY=<your-nim-api-key>
COVERREADY_PARSE_MODEL=nvidia/nemotron-parse
COVERREADY_OCR_MODEL=nvidia/nemotron-ocr-v1
